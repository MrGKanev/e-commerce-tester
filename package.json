{
  "name": "e-commerce-tester",
  "version": "1.0.0",
  "description": "Automated health check for Shopify store",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "test": "bash run.sh",
    "test:headed": "bash run.sh --headed",
    "test:debug": "bash run.sh --debug",
    "history": "open reports/history.html 2>/dev/null || xdg-open reports/history.html",
    "install:browsers": "pnpm exec playwright install chromium",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.5.0",
    "lighthouse": "^13.0.3",
    "playwright-lighthouse": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
