{
  "name": "e-commerce-tester",
  "version": "1.0.0",
  "description": "Automated health check for Shopify store",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11"
  },
  "scripts": {
    "test": "bash run.sh",
    "test:headed": "bash run.sh --headed",
    "test:debug": "bash run.sh --debug",
    "dashboard": "open reports/dashboard.html 2>/dev/null || xdg-open reports/dashboard.html",
    "install:browsers": "pnpm exec playwright install chromium firefox webkit",
    "type-check": "tsc --noEmit",
    "lint": "eslint tests/ *.ts",
    "lint:fix": "eslint tests/ *.ts --fix",
    "format": "prettier --write \"tests/**/*.ts\" \"*.ts\"",
    "format:check": "prettier --check \"tests/**/*.ts\" \"*.ts\""
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.0.0",
    "lighthouse": "^13.0.3",
    "playwright-lighthouse": "^4.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
